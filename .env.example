# .env.example — copy to .env and fill in your values

# AlertEngine
ALERTENGINE_REDIS_URL=redis://localhost:6379/0

# Twilio WhatsApp (get from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+2637XXXXXXXX

# Your public URL (use ngrok for local demo)
# ngrok http 8000 → copy the https URL here
BASE_URL=https://xxxx.ngrok-free.app
